# ── Виртуальное окружение ────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Python артефакты ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── PyInstaller ───────────────────────────────────────────────────────────────
build/
dist/
!dist/
dist/*
!dist/ImageVisionAI.exe
*.spec

# ── Логи ─────────────────────────────────────────────────────────────────────
*.log

# ── Конфиг (содержит локальный адрес сервера) ────────────────────────────────
server_config.json

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Изображения (не коммитим случайные файлы) ────────────────────────────────
*.png
*.jpg
*.jpeg
*.bmp
*.tiff
*.webp
# Исключение: иконка приложения и примеры
!icon.ico
!examples/*.png
!examples/*.jpg
!examples/*.jpeg
